{% comment %}
DO NOT EDIT THIS!
UPDATE THE CORRESPONDING THEME INSTEAD!
THEME CAN BE FOUND AT Career Sites > Theme Manager > TAIT Theme

ONCE THEME HAS BEEN UPDATED, RE-APPLY IT TO ALL APPLICABLE SITES
{% endcomment %}

<!doctype html>
<html class="no-js" lang="{{ current_locale.locale }}">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
        
        <link rel="shortcut icon" type="image/x-icon" href="/system/production/assets/442644/original/tait__icon.png">
        <link rel="stylesheet" href="https://dhbhdrzi4tiry.cloudfront.net/cdn/sites/foundation.min.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

        <!--Fonts-->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

        <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
        {% careersites_required_head_tags %}
        <script>var $cs = $;</script>

        {% include '_config__reusable-texts' %}
        {% include '/_config__variables' %}

        {% capture page_title %}{% careersites_required_title %}{% endcapture %}

        <!--SEO Meta Content Logic-->
        <title>{{ meta_title }}</title>

        {% if seo_to_index == 'true' %}
            {% if root_url contains 'preview' or root_url contains '-dev' %}
                <meta name="robots" content="noindex, nofollow">
            {% else %}
                {% if job %}
                    <meta name="robots" content="index, nofollow">
                {% else %}
                    <meta name="robots" content="index, follow">
                {% endif %}
            {% endif %}
        {% else %}
            <meta name="robots" content="noindex, nofollow">
        {% endif %}

        {% capture current_url_with_current_locale_permalink %}{{ request_host_with_port }}{{ locale_permalink }}{% endcapture %}
        {% capture current_url %}https://{{ request_host_with_port }}{{ request_path }}{% endcapture %}
        {% capture canonical_url %}{{ current_url | replace: current_url_with_current_locale_permalink,request_host_with_port }}{% endcapture %}
        <link rel="canonical" href="{{ canonical_url }}" />

        {% for locale in available_locales %}
            {% capture current_url_with_locale_permalink %}{{ request_host_with_port }}/{{ locale.locale }}{% endcapture %}
            {% capture locale_canonical_url %}{{ canonical_url | replace: request_host_with_port,current_url_with_locale_permalink }}{% endcapture %}
            <link href="{{ locale_canonical_url }}" hreflang="{{ locale.locale }}" rel="alternate" type="text/html"/>
        {% endfor %}

        {% if meta_description != blank %}
            <meta name="description" content="{{ meta_description }}">
        {% endif %}
        {% comment %}
        {% if meta_keywords != blank %}
            <meta name="keywords" content="{{ meta_keywords }}">
        {% endif %}
        Removed because meta keywords are outdated, irrelevant and has no impact on search engine rankings; and could even hurt SEO
        {% endcomment %}
        <!--END SEO Meta Content Logic-->

        <meta property="og:title" content="{{ meta_title }}" />
        <meta property="og:type" content="website" />
        <meta property="og:image" content="/system/production/assets/442645/original/tait__social-share.jpg" />
        <meta property="og:url" content="{{ root_url }}{{ request_fullpath | remove_first: '/' }}" />
        {% if meta_description != blank %}<meta property="og:description" content="{{ meta_description }}" />{% endif %}
        <meta property="og:locale" content="{% if current_locale.locale != blank %}{{ current_locale.locale }}{% else %}en{% endif %}" />
        <meta property="og:site_name" content="{{ company_name }}" />

        {% comment %}Logic for Prod only code{% endcomment %}
        {% if root_url contains 'preview' or root_url contains 'cm-' or root_url contains '-dev' %}
            {% capture is_dev %}true{% endcapture %}
        {% endif %}
        {% if is_dev != 'true' %}
            {% comment %}Prod only code here{% endcomment %}
        {% endif %}
    </head>
    <body id="{{ template.permalink }}" class="scroll{% if is_all_jobs == 'true' %} all-jobs{% endif %}">
        <!-- <div class="preloader-wrapper">
            <div class="preloader"></div>
        </div> -->

        <div class="width-detector"></div>
        <div class="locale-detector-js hide">{{ current_locale.locale }}</div>

        <div class="saved-jobs-alert-wrapper full-height full-width hide-for-print" role="alert">
            <div class="saved-jobs-alert">
                <div class="saved-jobs-alert__check padded-medium">
                    <i class="fa fa-circle-check" aria-hidden="true"></i>
                </div>
                <div class="saved-jobs-alert__message padded-medium"></div>
            </div><!--close .saved-jobs-alert-->
        </div><!--close .saved-jobs-alert-wrapper-->

        <div class="page-container fadeIn{% if job and params['savejob'] == '1' %} hide{% endif %}">

            <div class="hide">
                {% capture returnurl %}return_url\":\"http:\\\\\\\\\\\\\\\\{{career_site.domain}}/\"{% endcapture %}
                {% capture tn %}
                  {{ "Join our Talent Network" | link_to_talent_network: "talent-network-main", "talent-network-main" }}
                {% endcapture %}
                {{ tn | replace: 'return_url\":null', returnurl }}
            </div>

            <a class="skip-main branded-button-2 hide-for-print" href="#main" rel="nofollow">{{ text_skip_to_main_content }}</a>
            
            <div class="top-wrapper">
                <div class="header-anchor js"></div>
                <div class="header-outer">
                    <header>
                        <div class="row">
                            <div class="columns small-6 large-3 xlarge-6 header__logo padded-v-small">
                                <!-- <img src="/system/production/assets/442647/original/tait__logo--wht.png{% asset_seed %}" alt="{{ company_name }}" class="header__logo--wht" />
                                <img src="/system/production/assets/442648/original/tait__logo--blk.png{% asset_seed %}" alt="{{ company_name }}" class="header__logo--blk" /> -->
                                <a href="{% if site_type == 'external' %}https://www.taittowers.com/{% elsif site_type == 'internal' %}{{ root_url }}{% endif %}">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3464.1 1184.7" aria-labelledby="logo-" focusable="false"><title id="logo-">{{ company_name }}</title><path d="M1093,510.9H812.8v541.7H412.3V511.1H132.1v-379H1093V510.9z M1907.3,1052.6h397.8V132.1h-397.8V1052.6z M881.6,1052.6  h400.5l78.6-151.1l78.6,151.1h400.5l-479.2-920.6L881.6,1052.6z M2371.1,132.1v379h280.2v541.5h400.5V510.9h280.2V132.1H2371.1z" fill="#fff"></path><path d="M1093,510.9H812.8v541.7H412.3V511.1H132.1v-379H1093V510.9z M1907.3,1052.6h397.8V132.1h-397.8V1052.6z M881.6,1052.6  h400.5l78.6-151.1l78.6,151.1h400.5l-479.2-920.6L881.6,1052.6z M2371.1,132.1v379h280.2v541.5h400.5V510.9h280.2V132.1H2371.1z"></path></svg>
                                </a>
                            </div>
                            <div class="hide-for-print columns small-6 header__menu-mobile hide-for-large">
                                <span class="header__menu-mobile-button">
                                    <a href="javascript:void(0);" aria-expanded="false" rel="nofollow" class="hide-for-large">
                                        <span clsas="hide-for-large"><i class="fa fa-bars" aria-hidden="true"></i><span class="show-for-sr">{{ text_menu }}</span></span>
                                    </a>
                                    <a href="javascript:void(0);" aria-expanded="false" rel="nofollow" class="show-for-large"><span class="header__menu-open">{{ text_menu }}</span><span class="header__menu-close">{{ text_close }}</span></a>
                                </span>
                            </div>
                            <div class="columns large-9 xlarge-6">
                                <div class="hide-for-print columns header__menu background-dark" aria-hidden="true">
                                    <div class="row">
                                        <div class="columns large-8 xlarge-9">
                                            <nav>
                                                <ul class="clearfix">
                                                    <li><a href="/{{ current_locale.locale }}/search/jobs">{{ text_search_jobs }}</a></li>
                                                    <li><a href="/{{ current_locale.locale }}/pages/saved-jobs" class="saved_jobs_link" rel="nofollow">{{ text_saved_jobs }}</a></li>
                                                    <li><a href="{{ current_locale.locale | candidate_portal_url }}" target="_blank" rel="nofollow">{% if site_type == 'internal' %}{{ text_employee_portal }}{% else %}{{ text_candidate_portal }}{% endif %}</a></li>
                                                </ul>
                                            </nav>
                                        </div>
                                        <div class="columns large-4 xlarge-3 padded-v-small">
                                            <div class="header__top-language-select-outer">
                                                <select class="header__top-language-select-js">
                                                    {% for locale in available_locales %}
                                                        <option value="{{ locale.url }}"{% if locale.locale == current_locale.locale %} selected{% endif %}>{{ locale.label }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </header><!--close header-->
                </div><!--close .header-outer-->

                {% if is_home_page == 'true' or is_all_jobs == 'true' %}
                    <div class="page-banner screen-section- background-dark padded-v-xlarge" style="background-image: url('/system/production/assets/448340/original/all-jobs__banner--v6.jpg');">
                        <div class="row padded-v-xlarge">
                            <div class="column large-offset-3 large-9 xlarge-offset-6 xlarge-6">
                                <h1>{{ text_careers_at_company }}</h1>
                                {{ text_job_search_heading }}
                                <div class="row">
                                    <div class="column medium-8 large-9 xlarge-7 end">
                                        <div class="space-large"></div>
                                        <div class="branded-search">
                                            <div class="space-small"></div>
                                            <div class="cs_item_type_jobsearch cs_cfix cs_jsearchform">
                                                <form id="search_form---" method="get" action="/{{ current_locale.locale }}/search/jobs" class="search-form">
                                                    <div class="row">
                                                        <div class="column">
                                                            <div class="space-small">
                                                                <label for="cs_jobsearchforminput_keyword" class="show-for-sr">{{ text_keyword_job_title_skills }}</label>
                                                                <input type="text" placeholder="{{ text_keyword_job_title_skills }}" id="cs_jobsearchforminput_keyword" class="ui-autocomplete-input full-width" autocomplete="off" name="q" value="{{ params['q'] | escape_html }}"><span role="status" aria-live="polite" class="ui-helper-hidden-accessible"></span>
                                                            </div>
                                                            <div class="space-small">
                                                                <label for="search__location" class="show-for-sr">{{ text_enter_a_location }}</label>
                                                                <input type="text" name="location" value="{{ params['location'] | escape_html }}" placeholder="{{ text_enter_a_location }}" id="search__location" class="full-width" />
                                                            </div>
                                                            <div class="space-small text-right">
                                                                <input type="submit" value="{{ text_find_jobs }}" class="branded-button-3">
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div><!--close .cs_item_type_jobsearch.cs_cfix cs_jsearchform-->
                                        </div><!--close .branded-search-->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--close .page-banner-->
                {% endif %}
            </div><!--close .top-wrapper-->

            
            <div class="template-content{% if params['savejob'] == '1' %} hide{% endif %}{% if is_job_search == 'true' %} background-1 background-dark{% endif %}">
                <div id="main" tabindex="-1"></div>
                {% if is_all_jobs != 'true' %}
                    <div class="hide-for-print padded-v-small background-1 branded-search">
                        <div class="row">
                            <div class="column xlarge-6 xlarge-offset-6">
                                <div class="space-small"></div>
                                <div class="cs_item_type_jobsearch cs_cfix cs_jsearchform">
                                    <form id="search_form---" method="get" action="/{{ current_locale.locale }}/search/jobs" class="search-form">
                                        <div class="row">
                                            <div class="columns medium-9">
                                                <div class="row">
                                                    <div class="columns medium-6 space-small">
                                                        <label for="cs_jobsearchforminput_keyword" class="show-for-sr">{{ text_keyword_job_title_skills }}</label>
                                                        <input type="text" placeholder="{{ text_keyword_job_title_skills }}" id="cs_jobsearchforminput_keyword" class="ui-autocomplete-input" autocomplete="off" name="q" value="{{ params['q'] | escape_html }}"><span role="status" aria-live="polite" class="ui-helper-hidden-accessible"></span>
                                                    </div>
                                                    <div class="columns medium-6 space-small">
                                                        <label for="search__location" class="show-for-sr">{{ text_enter_a_location }}</label>
                                                        <input type="text" name="location" value="{{ params['location'] | escape_html }}" placeholder="{{ text_enter_a_location }}" id="search__location" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="columns medium-3">
                                                <div class="space-small">
                                                    <input type="submit" value="{{ text_find_jobs }}" class="branded-button-2">
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                                </div><!--close .cs_item_type_jobsearch.cs_cfix cs_jsearchform-->
                            </div>
                        </div>
                    </div><!--close .branded-search-->
                {% endif %}

                {{ template_content }}

            </div><!--close .template-content-->

            <footer>
                {% if site_type == 'external' %}
                    <div class="padded-v-xlarge talent-network-section background-6">
                        <div class="row">
                            <div class="column text-center padded-v-xlarge">
                                <div class="space-large">
                                    {{ text_talent_network_blurb }}
                                </div>
                                <a href="javascript:void(0);" class="branded-button-1 talent-network-link" rel="nofollow">
                                    {{ text_join_our_talent_network }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endif %}
                <div class="padded-v-medium background-1 background-dark">
                    <div class="row space-xlarge">
                        <div class="columns large-7 large-push-3 xlarge-8 xlarge-push-2 end">
                            <div class="row">
                                <div class="columns small-6 large-3- large-12 hide-for-print footer-menu">
                                    <h2>{{ text_sitemap }}</h2>
                                    <nav>
                                        <ul class="clearfix">
                                            <li><a href="https://www.taittowers.com/">{{ text_home }}</a></li>
                                            <li><a href="https://www.taittowers.com/work">{{ text_work }}</a></li>
                                            <li><a href="https://www.taittowers.com/about">{{ text_about }}</a></li>
                                            <li><a href="https://www.taittowers.com/careers">{{ text_careers }}</a></li>
                                            <li><a href="https://www.taittowers.com/announcements">{{ text_announcements }}</a></li>
                                        </ul>
                                    </nav>
                                </div>
                                <div class="columns small-6 large-3- large-12 hide-for-print footer-menu">
                                    <h2>{{ text_follow_us_on_social }}</h2>
                                    <nav>
                                        <ul class="clearfix">
                                            <li><a target="_blank" href="https://www.linkedin.com/company/tait-towers">LinkedIn</a></li>
                                            <li><a target="_blank" href="https://www.youtube.com/@TAIT">YouTube</a></li>
                                            <li><a target="_blank" href="https://www.instagram.com/taittowers/">Instagram</a></li>
                                            <li><a target="_blank" href="https://www.facebook.com/TAITTowers/">Facebook</a></li>
                                            <li><a target="_blank" href="https://twitter.com/TAITTowers">X</a></li>
                                        </ul>
                                    </nav>
                                </div>
                                <div class="columns small-6 large-3- large-12 hide-for-print footer-menu">
                                    <h2>{{ text_legal }}</h2>
                                    <nav>
                                        <ul class="clearfix">
                                            <li><a target="_blank" href="https://cdn.sanity.io/files/d1a1yw91/production/3d2508a660a786346c23a7eaa4e6dabe4594ab73.pdf">{{ text_anti_bribery_anti_corruption_statement }}</a></li>
                                            <li><a target="_blank" href="https://cdn.sanity.io/files/d1a1yw91/production/c1972a007509fe634bdbc268e272770c2d0b3321.pdf">{{ text_gdpr_policy }}</a></li>
                                            <li><a target="_blank" href="https://cdn.sanity.io/files/d1a1yw91/production/9a265e2ee296eed311098308e57af8b46f7b3384.pdf">{{ text_ccpa_ploicy }}</a></li>
                                            <li><a target="_blank" href="https://cdn.sanity.io/files/d1a1yw91/production/1dfc386e2c5a46fe0855bdb369b1ec58a9e82b6f.pdf">{{ text_contractors_licenses }}</a></li>
                                        </ul>
                                    </nav>
                                </div>
                                <div class="columns small-6 large-3- large-12 hide-for-print footer-menu">
                                    <h2>{{ text_yearbook }}</h2>
                                    <nav>
                                        <ul class="clearfix">
                                            <li><a target="_blank" href="https://user-jl6zmuz.cld.bz/TAIT-2023">2023</a></li>
                                            <li><a target="_blank" href="https://user-jl6zmuz.cld.bz/2022-TAIT-Yearbook">2022</a></li>
                                            <li><a target="_blank" href="https://user-jl6zmuz.cld.bz/2021-TAIT-Yearbook">2021</a></li>
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                        </div>

                        <div class="columns large-3 large-pull-9 xlarge-2 xlarge-pull-10 show-for-large">
                            <span class="color-3">{{ text_copyright | upcase }}</span><br />
                            {{ company_name }} &copy; {{ 'now' | date: "%Y" }}<br />
                            {{ text_all_rights_reserved | upcase}}
                        </div>
                    </div>

                    <div class="row footer-copyright">
                        <div class="columns large-6 end---">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3464.1 1184.7" aria-labelledby="logo-" focusable="false"><title id="logo-">{{ company_name }}</title><path d="M1093,510.9H812.8v541.7H412.3V511.1H132.1v-379H1093V510.9z M1907.3,1052.6h397.8V132.1h-397.8V1052.6z M881.6,1052.6  h400.5l78.6-151.1l78.6,151.1h400.5l-479.2-920.6L881.6,1052.6z M2371.1,132.1v379h280.2v541.5h400.5V510.9h280.2V132.1H2371.1z" fill="#fff"></path><path d="M1093,510.9H812.8v541.7H412.3V511.1H132.1v-379H1093V510.9z M1907.3,1052.6h397.8V132.1h-397.8V1052.6z M881.6,1052.6  h400.5l78.6-151.1l78.6,151.1h400.5l-479.2-920.6L881.6,1052.6z M2371.1,132.1v379h280.2v541.5h400.5V510.9h280.2V132.1H2371.1z"></path></svg>
                        </div>
                        <div class="columns large-6 large-offset-6--- small-text">
                            <span class="hide-for-large">{{ text_copyright | upcase }} {{ company_name }} &copy; {{ 'now' | date: "%Y" }} {{ text_all_rights_reserved | upcase}}<br /><br /></span>
                            <!-- <h2>Candidate Accommodations</h2> -->
                            {{ text_candidate_accommodations }}
                        </div>
                    </div>
                </div>
            </footer><!--close footer-->

        </div><!--close .page-container-->

        <script src="https://cdn.jsdelivr.net/npm/foundation-sites@6.6.3/dist/js/foundation.min.js" integrity="sha256-pRF3zifJRA9jXGv++b06qwtSqX1byFQOLjqa2PTEb2o=" crossorigin="anonymous"></script>
        <script>$(document).foundation();</script>
        {% careersites_required_footer %}
    </body>
</html>