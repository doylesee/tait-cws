{% comment %}
DO NOT EDIT THIS!
UPDATE THE CORRESPONDING THEME INSTEAD!
THEME CAN BE FOUND AT Career Sites > Theme Manager > TAIT Theme

ONCE THEME HAS BEEN UPDATED, RE-APPLY IT TO ALL APPLICABLE SITES
{% endcomment %}

{% include '_config__reusable-texts' %}
{% include '/_config__variables' %}

{% page_required_header %}

{% comment %}for similar jobs in Job Details page only {% endcomment %}
{% if params['ns_similar_jobs'] == '1' %}
    <div class="similar-jobs--jobs-search-js">
        {% for similar_job in jobs %}
            {% if params['ns_job_id'] == similar_job.id %}
                {% capture is_same_job %}true{% endcapture %}

            {% else %}
                {% if is_same_job != 'true' and forloop.index == 4 %}
                    <!--do nothing-->
                {% else %}
                    <div class="job-details__similar-jobs-item space-small">
                        <h3 class="heading-4">{{ similar_job | link_to_job }}</h3>
                        <p>
                            {% if similar_job.location.city != blank %}
                                {{ similar_job.location.city }}{% if similar_job.location.state_prov_short != blank or similar_job.location.country != blank %},{% endif %}
                            {% endif %}
                            {% if similar_job.location.state_prov_short != blank %}
                                {% capture job_location_state_prov_short_no_digit %}{{ similar_job.location.state_prov_short | replace_global_regex: "[\d]", ":::" }}{% endcapture %}
                                {% if job_location_state_prov_short_no_digit contains ':::' %}
                                    {{ similar_job.location.state_prov }}{% if similar_job.location.country != blank %},{% endif %}
                                {% else %}
                                    {{ similar_job.location.state_prov_short }}{% if similar_job.location.country != blank %},{% endif %}
                                {% endif %}
                            {% endif %}
                            {% if similar_job.location.country != blank %}{{ similar_job.location.country }}{% endif %}
                        </p>
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}
    </div>

{% comment %}if not for similar jobs{% endcomment %}
{% else %}
    {% comment %}Check if Saved Jobs are not all archived jobs{% endcomment %}
    {% if params['saved_jobs'] == '1' and jobs.total_entries == 0 %}
        <script type="text/javascript">
            var c_jobs_temp = localStorage.getItem('c_jobs_{{ current_locale.locale }}') ? JSON.parse(localStorage.getItem('c_jobs_{{ current_locale.locale }}')) : [];
            {% if current_locale.locale == 'en' %}
                {% assign en_locale_permalink = request_fullpath | slice: 0, 4 %}
            {% endif %}
            var current_saved_jobs_url = '{% if en_locale_permalink != blank and en_locale_permalink != '/en/' %}{{ locale_permalink }}{% endif %}{{ request_fullpath }}';
            current_saved_jobs_url = decodeURIComponent(current_saved_jobs_url);
            var saved_jobs_query = '/{{ current_locale.locale }}/search/jobs?external_id[]='+c_jobs_temp.join('&external_id[]=')+'&saved_jobs=1';

            if (saved_jobs_query == current_saved_jobs_url) {
                localStorage.removeItem('c_jobs_{{ current_locale.locale }}');
                setTimeout(function() {
                    {% capture saved_jobs_w_locale %}/{{ current_locale.locale }}/pages/saved-jobs{% endcapture %}
                    window.location.replace('{{ saved_jobs_w_locale }}');
                }, 2000);
            }
        </script>
    {% endif %}

    {% capture template_permalink_content_tag %}{{ template.permalink }}-content{% endcapture %}
    {{ template_permalink_content_tag | pages_with_tag | assign_to: 'template_permalink_content' }}

    {% if params['q'] == blank and params['location'] == blank %}
        {% assign facet_fields_array = "cfml1;cfml2;cfml3;cfml4;cfml5;cfml6;cfml7;cfml8;cfml9;cfml10" | split: ';' | assign_to: 'facet_fields' %}
        {% for facet_field in facet_fields %}
            {% if params[facet_field] != blank %}
                {% capture facet_field_value %}-{{ params[facet_field]  | replace: '/','-' | replace: ' - ','-' | replace: ' ','-' | downcase  }}{% endcapture %}
                {% assign facet_tag = facet_tag | append: facet_field_value | lstrip %}                
            {% endif %}
        {% endfor %}
    {% endif %}
    {% capture facet_content_tag %}search-{{ facet_tag | remove_first: '-' }}-jobs-content{% endcapture %}
    {{ facet_content_tag | pages_with_tag | assign_to: 'facet_content' }}

    {% if template_permalink_content.size > 0 %}
        {% capture jobs_category_content_tag %}{{ template_permalink_content_tag }}{% endcapture %}
    {% elsif facet_content.size > 0 %}
        {% capture jobs_category_content_tag %}{{ facet_content_tag }}{% endcapture %}
    {% else %}
        {% capture jobs_category_content_tag %}search-jobs-content{% endcapture %}
    {% endif %}

    {{ jobs_category_content_tag | pages_with_tag | assign_to: 'jobs_category_content' }}

    <div class="page-details-wrapper">
        <div class="jobs-category-banner">
            {% if jobs_category_content.size > 0 %}
                {% if jobs_category_content[0].images.size > 1 %}
                    <img src="{{ jobs_category_content[0].images[1].url }}" alt="{{ jobs_category_content[0].title }}" class="full-width" />
                {% else %}
                    <img src="{{ jobs_category_content[0].images[0].url }}" alt="{{ jobs_category_content[0].title }}" class="full-width" />
                {% endif %}
            {% endif %}
        </div>
                
        <div class="background-dark padded-v-large" style="background: #000;">

            <div class="jobs-category-section">
                <div class="row">
                    <div class="columns">
                        {% if params['saved_jobs'] == '1' %}
                            <h1 class="heading-2 space-medium">{{ text_saved_jobs }}</h1>
                        {% elsif jobs_category_content.size > 0 %}
                            <h1 class="heading-2 space-medium">{{ jobs_category_content[0].title }}</h1>
                            {{ jobs_category_content[0].content }}
                        {% elsif params['q'] != blank or params['ns_location'] != blank or params['location'] != blank %}
                            <h1 class="heading-2 space-medium">{{ text_search_results_heading }}</h1>
                        {% else %}
                            {% if is_all_jobs != 'true' %}
                                <h1 class="heading-2 space-medium">{{ text_job_search_results }}</h1>
                            {% endif %}
                            {% if params['ns_inactive_job'] == '1' %}
                                <p>{{ text_inactive_referral_job }}</p>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            </div><!--close .jobs-category-section-->

            <div class="jobs-heading">
                <div class="row">
                    <div class="columns">
                        <div class="space-medium">
                            {% if jobs.total_entries > 0 %}
                                {{ text_showing }}
                            {% endif %}
                            &nbsp;
                        </div>
                    </div>
                </div>
            </div><!--close .jobs-heading-->

            <div class="row{% if no_results_found %} row--small{% endif %}">
                {% if jobs.total_entries > 0 and params['saved_jobs'] != '1' %}
                    <div class="columns medium-4 large-3">
                        <div class="facet-section">
                            <section class="space-medium">
                                {% capture has_multiple_facet_options %}false{% endcapture %}
                                <div class="facet-section__heading hide">
                                    <a href="javascript:void(0);" class="facet-filter-results-button branded-button-2 hide-for-medium" rel="nofollow">{{ text_filter_your_results }}</a>
                                    <h2 class="heading-6 show-for-medium">
                                        {{ text_filter_your_results }}
                                        <span class="facet-section__clear-all text-small"><a href="{{ "cfm1_seo,cfm2_seo,cfm3_seo,cfm4_seo,cfm5_seo,cfm6_seo,cfm7_seo,cfm8_seo,cfm9_seo,job_tags_seo,location_country_seo,location_state_seo,location_city_seo" | get_facet_url_sans }}" rel="nofollow" class="facet-item__option-link js show-for-medium">{{ text_clear_all }}</a></span>
                                    </h2>
                                </div>

                                <div class="facet-section-inner">
                                    <!-- Assigning the Facets -->
                                    {% capture facet_feilds %}
                                        {{ text_category }}, cfm3_seo, multi, asc, 10, 100, collapsed;
                                        {{ text_country }}, location_country_seo, single, asc, 10, 100, collapsed;
                                        {{ text_state }}, location_state_seo, single, asc, 10, 100, collapsed;
                                        {{ text_city }}, location_city_seo, multi, asc, 10, 100, collapsed;
                                    {% endcapture %}

                                    {% assign facet_setup = facet_feilds | split: ';' | assign_to: 'facet_setup_split'; %}

                                    {% for facet_attrs in facet_setup_split %}
                                        <!-- Setting variables for the Facet attributes -->
                                        {{ facet_attrs | split: ', ' | assign_to: 'facet_attr' }}
                                        {% assign facet_heading = facet_attr[0] %}
                                        {% assign facet_field = facet_attr[1] %}
                                        {% assign facet_type = facet_attr[2] %}
                                        {% assign facet_order = facet_attr[3] %}
                                        {% assign facet_num_display = facet_attr[4] %}
                                        {% assign facet_num_limit = facet_attr[5] %}
                                        {% assign facet_expanded = facet_attr[6] %}

                                        {% capture facet_num_display_int %}{{ facet_num_display }}{% endcapture %}
                                        {% assign facet_num_display_int = facet_num_display_int | times: 1 %}

                                        <!-- Setting the Facets -->
                                        {% if facet_type == "multi" %}
                                            {{ facet_field | facet_multi: facet_num_limit, facet_order | assign_to: 'fa' }}
                                            {% assign facets = fa %}
                                        {% else %}
                                            {{ facet_field | facet_single: facet_num_limit, facet_order | assign_to: 'fa' }}
                                            {% assign facets = fa %}
                                        {% endif %}

                                        {% assign facet_results = facets[facet_field] %}

                                        {{ facet_field | selected_facets_by_name | assign_to: 'fas' }}
                                        {% assign facet_select = fas %}

                                        {% if facet_results.size > 1 or facet_select.size >= 1 %}
                                            {% if has_multiple_facet_options == 'false' %}
                                                <script>$('.facet-section__heading').removeClass('hide');</script>
                                            {% endif %}
                                            {% capture has_multiple_facet_options %}true{% endcapture %}
                                            
                                            {% if facet_select.size >= 1 %}
                                                <!-- Set variable to store Facet option Clear Filter link -->
                                                {% assign clear_filter = "" %}
                                                {% capture clear_filter %}{{ facet_field | get_facet_url_sans }}{% endcapture %}
                                            {% endif %}

                                            <div class="facet-item padded-v-small {% if facet_select.size < 1 and facet_expanded != 'expanded' %}facet-item--collapsed plus{% else %}facet-item--expanded minus{% endif %}">
                                                <div class="facet-item__heading padded-h-xsmall">
                                                    <button class="heading-6 space-none js" aria-expanded="{% if facet_expanded != 'expanded' %}false{% else %}true{% endif %}">{{ facet_heading | strip | lstrip }} <span class="facet-item__heading-expand-collapse text-right"></span></button>
                                                </div>
                                                <div class="facet-item__options padded-h-small">
                                                    <div class="space-small"></div>
                                                    {% assign facet_num_limit_counter = "0" %}
                                                    {% for facet in facet_results %}
                                                        {% if facet['permalink'] != "" %}

                                                            {% if facet_num_limit_counter == "0" %}
                                                                <div class="facet-item__row">
                                                            {% endif %}

                                                            {% if facet_num_limit_counter == facet_num_display %}
                                                                </div>

                                                                <div><a class="facet-item__show-more js" ref="{{ facet_field }}" href="javascript: void(0);" rel="nofollow">+ {{ text_show_more }}</a></div>

                                                                <div class="facet-item__row facet-item__row--hidden" id="facet-item__row--{{ facet_field }}">
                                                            {% endif %}

                                                            <div class="facet-item__options-item clearfix padded-v-xsmall">
                                                                <a href="{{ facet['query'] }}" class="facet-item__option-link js"{% if facet_select.size >= 1 %} rel="nofollow"{% endif %}>
                                                                    <span class="facet-item__options-item-type facet-item__options-item-type--{{ facet_type }} {% if facet['is_selected'] == true %}facet-item__options-item-type--selected{% endif %}"></span>
                                                                    <span class="facet-item__option-item-label">{{ facet["label"] }}</span>
                                                                    <span class="facet-item__option-item-count text-right">{{ facet["count"] }}<span class="show-for-sr">{{ text_jobs }}</span></span>
                                                                    <span class="show-for-sr">{% if facet['is_selected'] == true %}{{ text_selected }}{% endif %}</span>
                                                                </a>
                                                            </div>
                                                            {% capture facet_num_limit_counter %}{{ facet_num_limit_counter | plus: '1' }}{% endcapture %}
                                                        {% endif %}

                                                        {% if forloop.last and facet_num_limit_counter != "0" %}
                                                            </div>
                                                        {% endif %}

                                                        <!--Keep select facets after "Show More" open-->
                                                        {% if facet['is_selected'] == true and forloop.index > facet_num_display_int %}
                                                            <script>
                                                                $('.facet-item__show-more.js').addClass('hide');
                                                                $('.facet-item__row--hidden').removeClass('facet-item__row--hidden');
                                                            </script>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div><!--close .facet-item__options-->
                                                {% if facet_select.size >= 1 %}<div><a href="{{ clear_filter }}" class="facet-item__heading-clear text-small" rel="nofollow">{{ text_clear_filters }}</a></div>{% endif %}
                                            </div><!--close .facet-item-->
                                        {% endif %}
                                    {% endfor %}

                                    <div class="hide-for-medium padded-h-xsmall">
                                        <div class="space-large"></div>
                                        <a href="{{ "cfm1_seo,cfm2_seo,cfm3_seo,cfm4_seo,cfm5_seo,cfm6_seo,cfm7_seo,cfm8_seo,cfm9_seo,job_tags_seo,location_country_seo,location_state_seo,location_city_seo" | get_facet_url_sans }}" rel="nofollow" class="facet-item__option-link js">{{ text_clear_all }}</a>
                                        &nbsp;&nbsp;&nbsp;
                                        <a href="javascript:void(0);" class="facet-filter-results-button" rel="nofollow">{{ text_close }}</a>
                                    </div>
                                </div><!--close .facet-section-inner-->
                            </section>

                            <div class="padded-v-small">
                                <p><a href="javascript:void(0);" class="candidate-notification-link branded-button-3" rel="nofollow">{{ text_set_up_job_alerts }}</a></p>
                            </div>
                        </div><!--close .facet-section-->

                        {% capture visitor_personalization_section %}
                        <section class="copy-content background-dark">
                            {% if visitor.recent_jobs.total_entries > 0 or visitor.recent_job_searches.total_entries > 0 or visitor.recommended_jobs.total_entries > 0 %}
                                <div class="padded-v-small space-small">
                                    {% if visitor.recent_jobs.total_entries > 0 %}
                                        <div class="visitor-item-wrapper space-large">
                                            <h3 class="heading-6">{{ text_recently_viewed_jobs }}</h3>
                                            {% for job_data in visitor.recent_jobs limit: 5 %}
                                                <div class="visitor-item space-small"><a href="{{job_data.url}}" rel="nofollow">{{ job_data.title }}</a></div>
                                            {% endfor %}
                                        </div><!--close .visitor-item-wrapper-->
                                    {% endif %}

                                    {% comment %}check if there are valid recent job searches{% endcomment %}
                                    {% assign recent_job_search_counter = 0 %}
                                    {% capture recent_job_searches_list %}{% endcapture %}
                                    {% for search_data in visitor.recent_job_searches limit: 100 %}
                                        {% if search_data.url contains '?' %}
                                             {% if search_data.url contains 'external_id' or search_data.url contains 'per_page' %}
                                                {% capture valid_recent_search %}false{% endcapture %}
                                            {% else %}
                                                {% capture valid_recent_search %}true{% endcapture %}
                                            {% endif %}
                                        {% else %}
                                            {% if search_data.url contains '/search/jobs' %}
                                                {% capture valid_recent_search %}false{% endcapture %}
                                            {% else %}
                                                {% capture valid_recent_search %}true{% endcapture %}
                                            {% endif %}
                                        {% endif %}

                                        {% if valid_recent_search == 'true' %}
                                            {% assign recent_job_search_counter = recent_job_search_counter | plus: 1 %}
                                            {% capture recent_job_searches_list %}{{ recent_job_searches_list }}<div class="visitor-item space-small"><a href="{{ search_data.url }}" rel="nofollow">{{ search_data.title }}</a></div>{% endcapture %}
                                        {% endif %}
                                        {% if recent_job_search_counter >= 5 %}
                                            {% break %}
                                        {% endif %}
                                    {% endfor %}

                                    {% if visitor.recent_job_searches.total_entries > 0 and recent_job_searches_list != blank %}
                                        <div class="visitor-item-wrapper space-large">
                                            <h3 class="heading-6">{{ text_recent_job_searches }}</h3>
                                            {{ recent_job_searches_list }}
                                        </div><!--close .visitor-item-wrapper-->
                                    {% endif %}

                                    {% if visitor.recommended_jobs.total_entries > 0 %}
                                        <div class="visitor-item-wrapper space-large">
                                            <h3 class="heading-6">{{ text_recommended_jobs }}</h3>
                                            {% for job_data in visitor.recommended_jobs limit: 5 %}
                                                <div class="visitor-item space-small">{{ job_data | link_to_job }}</div>
                                            {% endfor %}
                                        </div><!--close .visitor-item-wrapper-->
                                    {% endif %}
                                </div><!--close .branded-box-->
                            {% else %}
                                {% comment %}
                                <div class="space-small"><span class="branded-button-outer branded-button-1-outer branded-button-wide-outer">{{ text_personalize_your_experience | link_to_social_login }}</span></div>
                                <!-- <span class="text-small"><a href="{{career_site.enable_tracking_url}}" rel="nofollow">Click here to enable personalized experience</a></span> -->
                                {% endcomment %}
                            {% endif %}
                        </section>
                        {% endcapture %}

                        <div class="show-for-medium">
                            {{ visitor_personalization_section }}
                        </div>
                    </div>
                {% endif %}

                <div class="columns {% if jobs.total_entries > 0 and params['saved_jobs'] != '1' %} medium-8 large-9 xlarge-8 xlarge-offset-1{% endif %}">
                    <section>
                        <div class="jobs-section">
                            <div class="hide">
                                {{ notificationlabel | candidate_job_notification_link }}
                            </div>
                            <div class="preloader preloader--search">
                                <div class="facet-jobs-loading hide--- hide-for-print" role="alert" aria-labelledby="facet-jobs-loading">
                                    <div class="show-for-sr"><label id="facet-jobs-loading">{{ text_loading_jobs }}</label></div>
                                </div>
                            </div>
                            <div class="jobs-section__inner">
                                {% if no_results_found %}
                                    <div class="copy-content background-dark">{{ text_no_results_found }}</div>
                                {% else %}

                                    <script>var current_year = new Date().getFullYear();</script>
                                    <div class="jobs-section__list space-medium">
                                        <div class="branded-search space-small hide-for-large">
                                            <div class="sortby-mobile-outer">
                                                <select class="sortby-mobile">
                                                    <option>{{ text_sort_by }} {{ params['sort_by'] | replace: 'default',text_relevance | replace: 'title',text_job_title | replace: 'location_city',text_location | replace: 'updated_at',text_date_posted }}</option>
                                                    <option value="default">{{ text_relevance }}</option>
                                                    <option value="title">{{ text_job_title }}</option>
                                                    <option value="location_city">{{ text_location }}</option>
                                                    {% if site_type == 'internal' %}<option value="updated_at">{{ text_date_posted }}</option>{% endif %}
                                                </select>
                                            </div>
                                        </div>

                                        <div class="facet-jobs-loaded hide--- hide-for-print" role="alert" aria-labelledby="facet-jobs-loaded">
                                            <div class="show-for-sr">
                                                <label id="facet-jobs-loaded">
                                                    {% if jobs.total_entries > 0 %}
                                                        {{ text_showing }}
                                                    {% endif %}
                                                </label>
                                            </div>
                                        </div><!--close .facet-loaded-jobs-->
                                        
                                        <div class="jobs-section__heading padded-v-small show-for-large">
                                            <div class="row">
                                                <div class="columns {% if site_type == 'internal' %}large-4{% else %}large-6{% endif %}">
                                                    <h3 class="heading-6"><a class="sort-button" href="javascript:sortjobs('title');" rel="nofollow">{{ text_job_title }} &nbsp;<i class="fa fa-sort text-small" aria-hidden="true"></i></a></h3>
                                                </div>
                                                <div class="columns large-6">
                                                    <h3 class="heading-6"><a class="sort-button" href="javascript:sortjobs('location_city');" rel="nofollow">{{ text_location }} &nbsp;<i class="fa fa-sort text-small" aria-hidden="true"></i></a></h3>
                                                </div>
                                                {% if site_type == 'internal' %}
                                                <div class="columns large-2">
                                                    <h3 class="heading-6"><a class="sort-button" href="javascript:sortjobs('updated_at');" rel="nofollow">{{ text_date_posted }} &nbsp;<i class="fa fa-sort text-small" aria-hidden="true"></i></a></h3>
                                                </div>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <script>
                                            // Sort by functionality
                                            $('.sortby-mobile').change(function() {
                                                sortjobs($(this).val());
                                            });
                                            
                                            function sortjobs(new_sortfield) {
                                                var current_job_url = '{{ request_fullpath | escape_javascript | replace: '%2C',',' }}';
                                                {% capture params_sortby_escaped %}{{ params['sort_by'] | escape_javascript }}{% endcapture %}
                                                var params_sortby_escaped = '{{ params_sortby_escaped }}';
                                                var current_sortfield = '';
                                                var current_sortorder = '';
                                                var new_sortorder = '';
                                                var new_job_url = '';

                                                {% if params['sort_by'] != blank %}
                                                    {% assign sortbyfield = params_sortby_escaped | split: ',' | assign_to: 'sortby_params' %}
                                                    current_sortfield = '{{ sortby_params[0] }}';
                                                    current_sortorder = '{{ sortby_params[1] }}';
                                                {% endif %}

                                                if (new_sortfield == 'default') {
                                                    new_sortorder = '';
                                                }
                                                else if (new_sortfield == current_sortfield) {
                                                    if (current_sortorder == 'asc') {
                                                        new_sortorder = ',desc';
                                                    }
                                                    else {
                                                        new_sortorder = ',asc';
                                                    }
                                                }
                                                else {
                                                    new_sortorder = ',asc'; 
                                                }

                                                {% if params['sort_by'] != blank %}
                                                    new_job_url = current_job_url.replace('{{ params_sortby_escaped }}',new_sortfield+new_sortorder);
                                                {% elsif request_fullpath contains '?' %}
                                                    new_job_url = current_job_url+'&sort_by='+new_sortfield+new_sortorder;
                                                {% else %}
                                                    new_job_url = current_job_url+'/?sort_by='+new_sortfield+new_sortorder;
                                                {% endif %}
                                                ds_tm_get_jobs_ajax(new_job_url);
                                            }
                                        </script>
                                        {% for job in jobs %}
                                            <div class="jobs-section__item padded-v-medium">
                                                <div class="row">
                                                    <div class="columns {% if site_type == 'internal' %}large-4{% else %}large-6{% endif %}">
                                                        {% assign date_job = job.created_at | date: '%s' %}
                                                        {% assign date_current = 'now' | date: '%s' %}
                                                        {% assign diff_seconds = date_current | minus: date_job %}
                                                        {% assign diff_days = diff_seconds | divided_by: 3600.0 | divided_by: 24.0 %}
                                                        <h4 class="space-none">
                                                            {% if diff_days < 13.5 %}
                                                                {% capture is_new_label %} <sup class="text-small">{{ text_new }}</sup></a>{% endcapture %}
                                                                {{ job | link_to_job | replace: '<a','<a class="job-is-new"' | replace: '</a>',is_new_label }}

                                                            {% else %}
                                                                {{ job | link_to_job }}

                                                            {% endif %}
                                                        </h4>
                                                    </div>
                                                    <div class="columns large-6">
                                                        <span class="hide">{{ text_location }}: </span>
                                                        {% if job.location.city != blank %}
                                                            {{ job.location.city }}{% if job.location.state_prov_short != blank or job.location.country != blank %},{% endif %}
                                                        {% endif %}
                                                        {% if job.location.state_prov_short != blank %}
                                                            {% capture job_location_state_prov_short_no_digit %}{{ job.location.state_prov_short | replace_global_regex: "[\d]", ":::" }}{% endcapture %}
                                                            {% if job_location_state_prov_short_no_digit contains ':::' %}
                                                                {{ job.location.state_prov }}{% if job.location.country != blank %},{% endif %}
                                                            {% else %}
                                                                {{ job.location.state_prov_short }}{% if job.location.country != blank %},{% endif %}
                                                            {% endif %}
                                                        {% endif %}
                                                        {% if job.location.country != blank %}{{ job.location.country }}{% endif %}
                                                    </div>
                                                    {% if site_type == 'internal' %}
                                                    <div class="columns large-2"><span class="hide-for-large">{{ text_date_posted }}: </span><time datetime="{{ job.updated_at | date: '%Y-%m-%d' }}">{{ job.updated_at | date: '%b %-d, %Y' | replace: 'Jan',text_january | replace: 'Feb',text_february | replace: 'Mar',text_march | replace: 'Apr',text_april | replace: 'May',text_may | replace: 'Jun',text_june | replace: 'Jul',text_july | replace: 'Aug',text_august | replace: 'Sep',text_september | replace: 'Oct',text_october | replace: 'Nov',text_november | replace: 'Dec',text_december }}</time></div>
                                                    {% endif %}
                                                </div>
                                            </div>  
                                        {% endfor %}
                                    </div><!--close .jobs-section__list-->
                                    <div class="jobs-section__paginate space-large">
                                        <a href="{{ request_fullpath }}{% if request_fullpath contains '?' %}&{% else %}?{% endif %}page=2" class="jobs-section__paginate-view-more" rel="nofollow">{{ text_view_more_jobs }}</a>
                                        {{ jobs | paginate | replace: 'previous',text_previous | replace: 'next',text_next }}
                                    </div>
                                {% endif %}
                            </div><!--close .jobs-section__inner-->
                        </div><!--close .jobs-section-->

                        <div class="hide-for-medium">
                            {{ visitor_personalization_section }}
                        </div>
                    </section>
                </div>
            </div><!--close .row-->

        </div>
    </div><!--close .page-details-wrapper-->

{% endif %}{% comment %}END if params['ns_similar_jobs'] == 1{% endcomment %}
 
{% page_required_footer %}